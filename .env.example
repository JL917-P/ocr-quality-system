# Copia a .env solo para desarrollo local (no subir .env a GitHub)

# Panel principal (producción)
PUBLIC_APP_URL=https://ocr-quality-system.onrender.com

# Puerto del servidor (solo local / Docker)
PORT=8000

# Windows: ruta a tesseract.exe (en Linux/Docker no hace falta)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Base de datos SQLite (local)
# DATA_DIR=./backend/data
# DATABASE_PATH=./backend/results.db

# Producción Render (disco persistente, ya va en render.yaml)
# DATA_DIR=/var/data
# DATABASE_PATH=/var/data/results.db

# Google Sheets (opcional)
# Local: archivo JSON en secrets/
# GOOGLE_CREDENTIALS_PATH=../secrets/chatbot-registros-7bc8f90366fd.json
# Render: pegar el JSON completo como secreto (una línea)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# GOOGLE_SPREADSHEET_NAME=ocr_control_calidad
# GOOGLE_SHEET_TAB_CLIENTES=CLIENTES
# GOOGLE_SHEET_TAB_PRODUCTOS=PRODUCTOS
# GOOGLE_SHEET_TAB_TRANSPORTES=TRANSPORTES
# GOOGLE_SHEET_TAB_CONSTANCIAS=CONSTANCIAS
# GOOGLE_SHEET_TAB_TRASIEGOS=TRASIEGOS
